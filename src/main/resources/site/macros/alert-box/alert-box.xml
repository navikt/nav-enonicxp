<macro>
    <display-name>Infokort</display-name>
    <description>Infokort med rik tekst</description>
    <form>
        <input type="HtmlArea" name="body">
            <label>Innhold</label>
            <occurrences minimum="1" maximum="1" />
            <config>
                <include>Undo Redo</include>
                <exclude>JustifyBlock Underline Macro Image</exclude>
                <allowHeadings>h3 h4 normal</allowHeadings>
            </config>
        </input>
    </form>
</macro>